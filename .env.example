# ============================================================
# WEBSTER-SHOP MVP backend environment configuration example
# ============================================================
# Copy this file to .env and replace placeholder values.
# Example: cp .env.example .env

# -----------------------------
# Core application
# -----------------------------
APP_NAME=WEBSTER-SHOP Backend
APP_ENV=dev
LOG_LEVEL=INFO

# -----------------------------
# Database
# -----------------------------
# SQLite-first default (recommended local/runtime setup):
DATABASE_URL=sqlite:///./webster_shop.db
# Optional PostgreSQL DSN (compatibility/testing only):
# DATABASE_URL=postgresql+psycopg://webster_shop:webster_shop@localhost:5432/webster_shop
SQL_ECHO=false

# -----------------------------
# Telegram bot
# -----------------------------
# Required to run bot flows (start/language/catalog/orders/top-up).
TELEGRAM_BOT_TOKEN=replace_with_real_bot_token
# Comma-separated Telegram user IDs allowed to open bot admin panel.
ADMIN_TELEGRAM_IDS=123456789

# -----------------------------
# External activation service
# -----------------------------
# Required for /activation flow. This is an external dependency.
ACTIVATION_API_BASE_URL=http://127.0.0.1:9000
ACTIVATION_API_TIMEOUT_SECONDS=10

# -----------------------------
# Crypto Pay (real order payments)
# -----------------------------
# If token is set, bot order payments use Crypto Pay (provider=crypto_pay).
CRYPTOPAY_API_TOKEN=replace_with_real_cryptopay_token
# true -> https://testnet-pay.crypt.bot/api ; false -> https://pay.crypt.bot/api
CRYPTOPAY_USE_TESTNET=true
# Optional override. If empty, URL is resolved from CRYPTOPAY_USE_TESTNET.
# CRYPTOPAY_API_BASE_URL=https://testnet-pay.crypt.bot/api
CRYPTOPAY_ASSET=USDT
# Invoice lifetime in seconds.
CRYPTOPAY_INVOICE_EXPIRES_IN=1800

# -----------------------------
# Blockchain verification (top-up by TXID)
# -----------------------------
# Explorer API endpoints by network key.
BLOCKCHAIN_EXPLORER_BASE_URLS={"bsc":"https://api.bscscan.com/api"}
# API keys by network key.
BLOCKCHAIN_EXPLORER_API_KEYS={"bsc":"replace_with_real_bscscan_api_key"}
# Allowed amount mismatch tolerance for tx verification.
BLOCKCHAIN_AMOUNT_TOLERANCE=0
# Supported crypto top-up options displayed in bot.
BLOCKCHAIN_SUPPORTED_CRYPTO_OPTIONS={"bsc_usdt":{"network":"bsc","display_label":"USDT BSC (BEP20)","token_symbol":"usdt","token_contract":"0x55d398326f99059ff775485246999027b3197955","token_decimals":18,"recipient_wallet":"0xyour_deposit_wallet","is_native_coin":false}}

# NOTE:
# - Demo seed data is development-only and must not be used in production.
# - Never commit real secrets/tokens/api keys to git.

# Transaction fee for external payments (top up and order invoices).
TRANSACTION_FEE_PERCENT=3.00

# Bybit top-up settings (MVP manual verification flow).
BYBIT_ENABLED=true
BYBIT_PAYMENTS_ENABLED=false
BYBIT_RECIPIENT_UID=replace_with_bybit_uid
BYBIT_RECIPIENT_NOTE=Send transfer to UID and provide sender UID/reference in bot

BYBIT_AUTO_VERIFY_ENABLED=false
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_API_BASE_URL=https://api.bybit.com
BYBIT_RECV_WINDOW=5000
BYBIT_DEPOSIT_COIN=USDT
BYBIT_INTERNAL_TRANSFER_LOOKBACK_MINUTES=180
BYBIT_INTERNAL_TRANSFER_POLL_SECONDS=0
BYBIT_REQUIRE_SENDER_UID=true
